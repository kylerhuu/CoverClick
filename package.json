{
  "name": "coverclick",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite build --watch\" \"vite build --watch --config vite.content.config.ts\"",
    "dev:app": "vite build --watch",
    "dev:content": "vite build --watch --config vite.content.config.ts",
    "build": "vite build",
    "build:content": "vite build --config vite.content.config.ts",
    "store:zip": "npm run build && rm -f coverclick-extension.zip && cd dist && zip -r ../coverclick-extension.zip .",
    "typecheck": "tsc --noEmit",
    "server:dev": "npm run dev --prefix server",
    "server:build": "npm run build --prefix server"
  },
  "dependencies": {
    "docx": "^9.1.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "concurrently": "^9.1.2"
  }
}
