# Extension build-time defaults (Vite). Copy to `.env` (local) or `.env.production` (deployed API).
#
# Local API testing (with `npm run server:dev` on port 8787):
#   VITE_COVERCLICK_API_ORIGIN=http://localhost:8787
#
# Production (no trailing slash):
#   VITE_COVERCLICK_API_ORIGIN=https://api.yourdomain.com

# VITE_COVERCLICK_API_ORIGIN=http://localhost:8787

# Optional: force mock generation in the built extension (skips Google / Stripe gate for UI-only dev)
# VITE_USE_MOCK=true
