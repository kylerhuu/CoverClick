{
  "manifest_version": 3,
  "name": "CoverClick",
  "version": "0.1.0",
  "description": "One-click tailored cover letters from any job posting.",
  "icons": {
    "16": "icons/coverclick-icon.png",
    "32": "icons/coverclick-icon.png",
    "48": "icons/coverclick-icon.png",
    "128": "icons/coverclick-icon.png"
  },
  "action": {
    "default_title": "CoverClick",
    "default_icon": {
      "16": "icons/coverclick-icon.png",
      "32": "icons/coverclick-icon.png",
      "48": "icons/coverclick-icon.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "permissions": ["activeTab", "identity", "storage", "scripting", "tabs", "sidePanel"],
  "host_permissions": ["https://*/*", "http://*/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
