generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SubscriptionStatus {
  NONE
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
}

enum JobApplicationStatus {
  SAVED
  PREPARING
  READY_TO_APPLY
  APPLIED
  INTERVIEWING
  OFFER
  REJECTED
  ARCHIVED
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  /// Legacy email/password sign-in (optional when using Google only).
  passwordHash String?
  googleSub    String? @unique
  stripeCustomerId     String? @unique
  stripeSubscriptionId String?
  subscriptionStatus   SubscriptionStatus @default(NONE)
  subscriptionPeriodEnd DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile       StoredProfile?
  authExchanges AuthExchange[]
  applications  JobApplication[]
}

model JobApplication {
  id             String               @id @default(cuid())
  userId         String
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  company        String               @default("")
  title          String               @default("")
  location       String               @default("")
  source         String               @default("")
  jobUrl         String
  jobDescription String               @default("") @db.Text

  dateSaved      DateTime             @default(now())
  dateApplied    DateTime?
  status         JobApplicationStatus @default(SAVED)

  fitScore           Int?
  resumeVariantId    String?
  resumeVariantName  String?
  resumeUsed         Json?
  coverLetterDraft   Json?
  resumeSuggestions  Json?
  preparationSteps   Json?
  preparationError   String?

  notes          String               @default("") @db.Text
  interviewDate  DateTime?
  followUpDate   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([userId, dateSaved])
  @@unique([userId, jobUrl])
}

model StoredProfile {
  userId    String   @id
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Full CoverClick `UserProfile` JSON (mirrors extension shape).
  data      Json
  updatedAt DateTime @updatedAt
}

/// One-time code returned to the extension after Google OAuth (exchanged for JWT).
model AuthExchange {
  code      String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

/// Processed Stripe webhook event ids — duplicates are acknowledged without re-running handlers.
model ProcessedStripeEvent {
  eventId    String   @id @map("event_id")
  receivedAt DateTime @default(now()) @map("received_at")

  @@map("processed_stripe_event")
}
