generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SubscriptionStatus {
  NONE
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  /// Legacy email/password sign-in (optional when using Google only).
  passwordHash String?
  googleSub    String? @unique
  stripeCustomerId     String? @unique
  stripeSubscriptionId String?
  subscriptionStatus   SubscriptionStatus @default(NONE)
  subscriptionPeriodEnd DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile       StoredProfile?
  authExchanges AuthExchange[]
}

model StoredProfile {
  userId    String   @id
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Full CoverClick `UserProfile` JSON (mirrors extension shape).
  data      Json
  updatedAt DateTime @updatedAt
}

/// One-time code returned to the extension after Google OAuth (exchanged for JWT).
model AuthExchange {
  code      String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

/// Processed Stripe webhook event ids — duplicates are acknowledged without re-running handlers.
model ProcessedStripeEvent {
  eventId    String   @id @map("event_id")
  receivedAt DateTime @default(now()) @map("received_at")

  @@map("processed_stripe_event")
}
