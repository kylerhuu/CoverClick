# SQLite database file (relative to server/)
DATABASE_URL="file:./dev.db"

# OpenAI (required for /api/generate-cover-letter and /api/me/parse-resume)
OPENAI_API_KEY="sk-..."
# Optional; default gpt-4o-mini
OPENAI_MODEL="gpt-4o-mini"
# Optional; cheap model for /api/clean-job-description fallback only (defaults to OPENAI_MODEL or gpt-4o-mini)
# OPENAI_CLEAN_MODEL="gpt-4o-mini"

# JWT signing secret (required for auth routes)
JWT_SECRET="change-this-to-a-long-random-string"

# Server port
PORT=8787
