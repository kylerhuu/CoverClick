# PostgreSQL (production / local). Example:
# DATABASE_URL="postgresql://user:password@localhost:5432/coverclick?schema=public"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/coverclick?schema=public"

# OpenAI (required for /api/generate-cover-letter and /api/me/parse-resume)
OPENAI_API_KEY="sk-..."
# Optional; default gpt-4o-mini
OPENAI_MODEL="gpt-4o-mini"
# OPENAI_CLEAN_MODEL="gpt-4o-mini"

# JWT signing secret (required for sessions)
JWT_SECRET="change-this-to-a-long-random-string"

# Server port
PORT=8787

# Public base URL of this API (no trailing slash). Used for Stripe return URLs and links in emails.
# Example: https://api.coverclick.com
PUBLIC_API_URL="http://localhost:8787"

# --- Google Sign-In (OAuth 2.0 authorization code flow) ---
# Create an OAuth "Web application" client in Google Cloud Console.
# Authorized redirect URI must be exactly:
#   {PUBLIC_API_URL or your API origin}/api/auth/google/callback
GOOGLE_CLIENT_ID="....apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="..."
GOOGLE_REDIRECT_URI="http://localhost:8787/api/auth/google/callback"

# --- Stripe (subscriptions) ---
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Price ID for a recurring subscription (e.g. price_...)
STRIPE_PRICE_ID="price_..."

# Comma-separated browser origins allowed in addition to chrome-extension://* and localhost.
# ALLOWED_ORIGINS=

RATE_LIMIT_AI_PER_MIN="30"
RATE_LIMIT_AUTH_PER_IP="40"
